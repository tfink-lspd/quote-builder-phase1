# Server Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database Configuration
DATABASE_URL=postgresql://quote_builder:password@localhost:5432/quote_builder_dev
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=quote_builder_dev
DATABASE_USER=quote_builder
DATABASE_PASSWORD=password

# JWT Configuration (for development)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Integration Configuration (Mock by default)
USE_MOCK_CATALOG=true
USE_MOCK_TAX=true
USE_MOCK_PAYMENTS=true
FALLBACK_TO_MOCK_ON_ERROR=true

# X-Series API URLs (leave empty to use mocks)
X_SERIES_CATALOG_API_URL=
X_SERIES_TAX_API_URL=
X_SERIES_PAYMENT_API_URL=
X_SERIES_AUTH_API_URL=

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3000
